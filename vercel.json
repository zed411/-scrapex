{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/results.html", "dest": "public/results.html" },
    { "src": "/results.css", "dest": "public/results.css" },
    { "src": "/results.js", "dest": "public/results.js" },
    { "src": "/app.js", "dest": "public/app.js" },
    { "src": "/(.*)", "dest": "public/$1" }
  ]
}
